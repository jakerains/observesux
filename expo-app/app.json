{
  "expo": {
    "name": "Siouxland Online",
    "slug": "siouxland-online",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "siouxland",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "icon": "./assets/icon.png",
      "deploymentTarget": "16.1",
      "supportsTablet": false,
      "bundleIdentifier": "com.siouxland.online",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleDisplayName": "SUX Online",
        "NSSupportsLiveActivities": true,
        "NSLocationWhenInUseUsageDescription": "Siouxland Online uses your location to show nearby traffic cameras, transit stops, and weather conditions.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.siouxland.online",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": "1.0.4",
    "updates": {
      "url": "https://u.expo.dev/7177e8d6-7bd1-4995-80e8-5286ee3b0720",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B35",
          "defaultChannel": "default"
        }
      ],
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7177e8d6-7bd1-4995-80e8-5286ee3b0720",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "SiouxlandWidgetsExtension",
                  "bundleIdentifier": "com.siouxland.online.widgets"
                }
              ]
            }
          }
        }
      }
    },
    "owner": "siouxlandonline"
  }
}
